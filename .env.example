# Copy to `.env.local` for development. Set the same keys in Cloudflare Pages / Workers project settings for production.

# --- Stripe Payment Links (https://) ---
# Website $100 deposit
NEXT_PUBLIC_STRIPE_WEBSITE_DEPOSIT_URL=

# Rescue $100 deposits (optional separate links; if blank, contact page uses mailto)
NEXT_PUBLIC_STRIPE_RESCUE_GOOGLE_DEPOSIT_URL=
NEXT_PUBLIC_STRIPE_RESCUE_META_DEPOSIT_URL=
NEXT_PUBLIC_STRIPE_RESCUE_SEO_DEPOSIT_URL=
NEXT_PUBLIC_STRIPE_RESCUE_BUNDLE_DEPOSIT_URL=

# Advisory membership (subscription or payment link)
NEXT_PUBLIC_STRIPE_ADVISORY_URL=

# --- Contact form (Formspree) ---
# Form ID only (not the full URL), e.g. `abcxyz` from https://formspree.io/f/abcxyz
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# --- Schema.org sameAs (optional, comma-separated URLs) ---
# Example: NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/in/yourprofile
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=
NEXT_PUBLIC_SOCIAL_GBP_URL=
NEXT_PUBLIC_SOCIAL_X_URL=
